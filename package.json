{
	"name": "@automattic/wcpay-cli",
	"version": "0.2.2",
	"description": "Standalone WooPayments CLI for developers, agents, and test-mode workflows.",
	"homepage": "https://github.com/Automattic/wcpay-cli#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/wcpay-cli.git"
	},
	"bugs": {
		"url": "https://github.com/Automattic/wcpay-cli/issues"
	},
	"type": "module",
	"bin": {
		"wcpay": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/app.d.ts",
			"import": "./dist/app.js"
		}
	},
	"files": [
		"dist",
		"docs/**/*.md",
		"README.md"
	],
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "npm run clean && tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
		"build:prepare": "npm run clean && npm exec --yes --package typescript -- tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
		"dev": "tsx src/cli.ts",
		"lint": "tsc -p tsconfig.json --noEmit",
		"docs:generate": "tsx scripts/generate-command-reference.ts",
		"docs:assets": "tsx scripts/render-doc-assets.ts",
		"docs:check": "tsx scripts/generate-command-reference.ts --check",
		"site:dev": "vitepress dev docs",
		"site:build": "vitepress build docs",
		"site:preview": "vitepress preview docs",
		"release:check": "tsx scripts/check-release-docs.ts",
		"install:smoke": "node scripts/smoke-github-install.cjs file:$PWD $npm_package_version",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "npm run lint && npm run docs:check && npm run release:check && npm run test && npm run site:build && npm run build && npm run install:smoke",
		"prepare": "npm run build:prepare && node scripts/install-husky-if-git.cjs",
		"pack:dry-run": "npm pack --dry-run",
		"format": "prettier --write ."
	},
	"keywords": [
		"woocommerce",
		"woopayments",
		"wcpay",
		"cli",
		"mcp"
	],
	"author": "Automattic",
	"license": "GPL-3.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.10"
	},
	"dependencies": {
		"@inquirer/prompts": "7.8.6",
		"@modelcontextprotocol/sdk": "1.29.0",
		"commander": "^12.1.0",
		"figlet": "1.11.0",
		"ora": "9.4.0",
		"picocolors": "1.1.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"husky": "9.1.7",
		"prettier": "^3.4.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitepress": "1.6.4",
		"vitest": "4.1.7"
	}
}
